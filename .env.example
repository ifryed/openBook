# PostgreSQL connection string
# Matches docker-compose.yml in this repo (user postgres / password postgres / db openbook):
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/openbook?schema=public"
#
# Site admins: set column is_admin = true on the User row (SQL, Prisma Studio, etc.).
# Admins can delete any book from the book page or “Edit book details”. Re-sign-in to refresh JWT.

# NextAuth — generate with: openssl rand -base64 32
AUTH_SECRET=""

# Public site URL (required for Google OAuth on Vercel / behind proxies).
# Use your real HTTPS origin, no trailing slash, e.g. https://YOUR_PROJECT.vercel.app
# If unset, Auth.js may guess the wrong host and Google returns redirect_uri_mismatch.
AUTH_URL=""

# Optional: trust forwarded Host (Vercel sets this; harmless locally)
AUTH_TRUST_HOST="true"

# Google OAuth (optional) — create a "Web application" OAuth client at
# https://console.cloud.google.com/apis/credentials
# Use client_id → AUTH_GOOGLE_ID, client_secret → AUTH_GOOGLE_SECRET from the downloaded JSON.
# Authorized JavaScript origins: http://localhost:3000 and https://YOUR_DOMAIN (no path)
# Authorized redirect URIs: http://localhost:3000/api/auth/callback/google and
#   https://YOUR_DOMAIN/api/auth/callback/google
# If the OAuth consent screen is in "Testing", add each sign-in email under Test users.
AUTH_GOOGLE_ID=""
AUTH_GOOGLE_SECRET=""

# Optional. Wikimedia APIs expect a descriptive User-Agent (see
# https://meta.wikimedia.org/wiki/User-Agent_policy). Example:
# REFERENCE_LOOKUP_USER_AGENT="OpenBook/1.0 (contact@yourdomain.example)"
REFERENCE_LOOKUP_USER_AGENT=""

# Optional. Full path to Calibre’s ebook-convert binary for MOBI/AZW3 book downloads.
# macOS example: /Applications/calibre.app/Contents/MacOS/ebook-convert
CALIBRE_EBOOK_CONVERT=""

# Optional. Chrome/Chromium binary for PDF book export when Puppeteer’s downloaded Chrome is missing.
# macOS example: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
PUPPETEER_EXECUTABLE_PATH=""

# Locale sync — run manually: npm run messages:sync (not part of npm run dev).
# One locale: npm run messages:sync -- he   (the "--" is required so npm passes "he" to the script).
# Source of truth: messages/en.json. Other locales are updated via local Ollama when reachable.
# If Ollama is down, missing keys fall back to English so the dev server still starts.
OLLAMA_HOST="http://127.0.0.1:11434"
# OLLAMA_MODEL="qwen2.5"
OLLAMA_MODEL="llama3.1"
# Optional tuning:
# OLLAMA_BATCH_SIZE="18"
# OLLAMA_BATCH_DELAY_MS="150"
# OLLAMA_CHAT_TIMEOUT_MS="180000"

# Optional. Transactional email (Resend — https://resend.com). When unset, notifications are in-app only.
# RESEND_API_KEY="re_..."
# From address must be a verified domain/sender in Resend.
# RESEND_FROM_EMAIL="OpenBook <notifications@yourdomain.example>"

# Optional. Google AdSense — copy into .env / .env.local (this file is not loaded by Next.js).
# Client id: ca-pub-… from AdSense (Account → Publisher ID). If you only have pub-…, the app prefixes ca-.
# Slot id: numeric ad unit id (Ads → By ad unit). Visible unit needs both; head script needs client id only.
NEXT_PUBLIC_ADSENSE_CLIENT_ID=""
NEXT_PUBLIC_ADSENSE_SLOT_ID=""
