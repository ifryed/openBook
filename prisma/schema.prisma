generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime? @map("email_verified")
  image         String?
  passwordHash  String?   @map("password_hash")

  accounts  Account[]
  sessions  Session[]
  books     Book[]
  revisions Revision[]
  reports   Report[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Book {
  id          String   @id @default(cuid())
  slug        String   @unique
  title       String
  figureName  String   @map("figure_name")
  /** Age range or audience label (e.g. "8–12", "Young adult", "General adult"). */
  intendedAges String  @default("") @map("intended_ages") @db.VarChar(255)
  summary     String?  @db.Text
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
  createdById String   @map("created_by_id")

  createdBy User      @relation(fields: [createdById], references: [id])
  sections  Section[]
  tags      BookTag[]
  reports   Report[]
}

model Section {
  id         String @id @default(cuid())
  bookId     String @map("book_id")
  slug       String
  title      String
  orderIndex Int    @default(0) @map("order_index")

  book      Book       @relation(fields: [bookId], references: [id], onDelete: Cascade)
  revisions Revision[]
  reports   Report[]

  @@unique([bookId, slug])
}

model Revision {
  id               String   @id @default(cuid())
  sectionId        String   @map("section_id")
  authorId         String   @map("author_id")
  body             String   @db.Text
  summaryComment   String?  @map("summary_comment")
  parentRevisionId String?  @map("parent_revision_id")
  createdAt        DateTime @default(now()) @map("created_at")

  section Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  author  User    @relation(fields: [authorId], references: [id])
}

model Tag {
  id    String    @id @default(cuid())
  slug  String    @unique
  name  String
  books BookTag[]
}

model BookTag {
  bookId String @map("book_id")
  tagId  String @map("tag_id")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([bookId, tagId])
}

model Report {
  id        String   @id @default(cuid())
  bookId    String?  @map("book_id")
  sectionId String?  @map("section_id")
  userId    String   @map("user_id")
  reason    String   @db.Text
  createdAt DateTime @default(now()) @map("created_at")

  book    Book?    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  section Section? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  user    User     @relation(fields: [userId], references: [id])
}
