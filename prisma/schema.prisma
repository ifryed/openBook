generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum NotificationType {
  NEW_REVISION
  NEW_BOOK
  NEW_SECTION
  REVERT
  REPORT_PUBLIC_COMMENT
  REPORT_RESOLVED
}

enum EmailNotifyMode {
  OFF
  ALL
  CUSTOM
}

enum ReportStatus {
  OPEN
  RESOLVED
}

enum ReportDisposition {
  CONTENT_ADDRESSED
  NO_ACTION_NEEDED
  INVALID_OR_ABUSIVE
}

enum ReportModerationLogKind {
  REPORT_FILED
  DISPOSITION_SET
  PUBLIC_COMMENT
  INTERNAL_NOTE
}

enum ReportModerationLogVisibility {
  PUBLIC
  STEWARD_ONLY
}

enum ReputationKind {
  REVISION_SAVED
  BOOK_CREATED
  SECTION_ADDED
  REVERT
  REPORT_RESOLVED
}

enum ContentDraftKind {
  BOOK
  CHAPTER
}

model User {
  id               String    @id @default(cuid())
  name             String?
  email            String    @unique
  emailVerified    DateTime? @map("email_verified")
  image            String?
  passwordHash     String?   @map("password_hash")
  /** Site moderators may remove books and use other admin-only tools. */
  isAdmin          Boolean   @default(false) @map("is_admin")
  reputationPoints Int       @default(0) @map("reputation_points")
  digestOptIn      Boolean   @default(false) @map("digest_opt_in")
  emailNotifyMode  EmailNotifyMode @default(OFF) @map("email_notify_mode")
  /** Used when emailNotifyMode is CUSTOM. */
  emailFromWatch           Boolean @default(true) @map("email_from_watch")
  emailFromDigest          Boolean @default(true) @map("email_from_digest")
  emailFromOwnedBooks      Boolean @default(true) @map("email_from_owned_books")
  emailReportUpdates       Boolean @default(true) @map("email_report_updates")
  emailTypeNewRevision     Boolean @default(true) @map("email_type_new_revision")
  emailTypeNewBook         Boolean @default(true) @map("email_type_new_book")
  emailTypeNewSection      Boolean @default(true) @map("email_type_new_section")
  emailTypeRevert          Boolean @default(true) @map("email_type_revert")
  emailTypeReportPublicComment Boolean @default(true) @map("email_type_report_public_comment")
  emailTypeReportResolved  Boolean @default(true) @map("email_type_report_resolved")

  accounts          Account[]
  sessions          Session[]
  books             Book[]
  revisions         Revision[]
  reports           Report[]
  resolvedReports   Report[]  @relation("ReportResolver")
  bookWatches       BookWatch[]
  notifications     Notification[]
  reputationEvents            ReputationEvent[]
  reportModerationLogEntries  ReportModerationLogEntry[]
  contentDrafts               ContentDraft[]
}

model Account {
  id                String  @id @default(cuid())
  userId            String  @map("user_id")
  type              String
  provider          String
  providerAccountId String  @map("provider_account_id")
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique @map("session_token")
  userId       String   @map("user_id")
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Book {
  id             String   @id @default(cuid())
  slug           String   @unique
  title          String
  figureName     String   @map("figure_name")
  /** Fixed audience band from app list (e.g. "8-10", "teens", "adults"). */
  intendedAges   String   @default("") @map("intended_ages") @db.VarChar(255)
  /** Country or region associated with the figure or setting (optional, for browsing). */
  country        String   @default("") @map("country") @db.VarChar(255)
  summary        String?  @db.Text
  /** BCP-47-style code; fallback locale for titles and notifications. */
  defaultLocale  String   @default("en") @map("default_locale") @db.VarChar(16)
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")
  createdById    String   @map("created_by_id")
  /** Hidden from the public catalog until published; only the creator (and admins) may view or edit. */
  isDraft        Boolean  @default(false) @map("is_draft")
  /** Successful file exports via `/api/books/.../download` (per completed response). */
  downloadCount  Int      @default(0) @map("download_count")

  createdBy     User               @relation(fields: [createdById], references: [id])
  sections      Section[]
  languages     BookLanguage[]
  titleLocales  BookLocalization[]
  tags          BookTag[]
  reports       Report[]
  watchers      BookWatch[]
  notifications Notification[]

  @@index([createdById, isDraft])
}

model BookLanguage {
  bookId String @map("book_id")
  locale String @db.VarChar(16)
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@id([bookId, locale])
  @@index([locale])
}

/** Per-locale book title; `Book.title` stays in sync with the default locale row for search and admin. */
model BookLocalization {
  bookId String @map("book_id")
  locale String @db.VarChar(16)
  title  String @db.Text
  book   Book   @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@id([bookId, locale])
  @@index([locale])
}

model Section {
  id         String @id @default(cuid())
  bookId     String @map("book_id")
  slug       String
  orderIndex Int    @default(0) @map("order_index")

  book            Book                  @relation(fields: [bookId], references: [id], onDelete: Cascade)
  localizations   SectionLocalization[]
  revisions       Revision[]
  reports         Report[]
  notifications   Notification[]

  @@unique([bookId, slug])
}

model SectionLocalization {
  sectionId String @map("section_id")
  locale    String @db.VarChar(16)
  title     String @db.VarChar(255)
  section   Section @relation(fields: [sectionId], references: [id], onDelete: Cascade)

  @@id([sectionId, locale])
  @@index([locale])
}

model Revision {
  id               String   @id @default(cuid())
  sectionId        String   @map("section_id")
  authorId         String   @map("author_id")
  locale           String   @default("en") @db.VarChar(16)
  body             String   @db.Text
  summaryComment   String?  @map("summary_comment")
  /** Plain-text “before” side for name/metadata diffs on the history page (paired with `labelDiffAfter`). */
  labelDiffBefore  String?  @map("label_diff_before") @db.Text
  /** Plain-text “after” side for name/metadata diffs on the history page. */
  labelDiffAfter   String?  @map("label_diff_after") @db.Text
  parentRevisionId String?  @map("parent_revision_id")
  createdAt        DateTime @default(now()) @map("created_at")

  section       Section        @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  author        User           @relation(fields: [authorId], references: [id])
  notifications Notification[]

  @@index([sectionId, locale, createdAt])
}

model Tag {
  id    String    @id @default(cuid())
  slug  String    @unique
  name  String
  books BookTag[]
}

model BookTag {
  bookId String @map("book_id")
  tagId  String @map("tag_id")

  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)
  tag  Tag  @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([bookId, tagId])
}

model BookWatch {
  id        String   @id @default(cuid())
  userId    String   @map("user_id")
  bookId    String   @map("book_id")
  createdAt DateTime @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  book Book @relation(fields: [bookId], references: [id], onDelete: Cascade)

  @@unique([userId, bookId])
  @@index([bookId])
}

model Notification {
  id         String           @id @default(cuid())
  userId     String           @map("user_id")
  type       NotificationType
  viaDigest  Boolean          @default(false) @map("via_digest")
  /** True when the user is the book creator (not a watcher); used for email/source prefs. */
  fromBookOwnership Boolean   @default(false) @map("from_book_ownership")
  readAt     DateTime?        @map("read_at")
  createdAt  DateTime         @default(now()) @map("created_at")
  bookId     String?          @map("book_id")
  sectionId  String?          @map("section_id")
  revisionId String?          @map("revision_id")
  reportId   String?          @map("report_id")
  actorId    String?          @map("actor_id")

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  book     Book?     @relation(fields: [bookId], references: [id], onDelete: Cascade)
  section  Section?  @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  revision Revision? @relation(fields: [revisionId], references: [id], onDelete: SetNull)
  report   Report?   @relation(fields: [reportId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt])
  @@index([reportId])
}

model ReputationEvent {
  id            String         @id @default(cuid())
  userId        String         @map("user_id")
  kind          ReputationKind
  delta         Int
  refBookId     String?        @map("ref_book_id")
  refSectionId  String?        @map("ref_section_id")
  refRevisionId String?        @map("ref_revision_id")
  refReportId   String?        @map("ref_report_id")
  createdAt     DateTime       @default(now()) @map("created_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, createdAt])
  @@index([userId, kind, createdAt])
}

model Report {
  id           String       @id @default(cuid())
  bookId       String?      @map("book_id")
  sectionId    String?      @map("section_id")
  userId       String       @map("user_id")
  reason       String       @db.Text
  createdAt    DateTime     @default(now()) @map("created_at")
  status       ReportStatus @default(OPEN)
  resolvedAt   DateTime?    @map("resolved_at")
  resolvedById String?      @map("resolved_by_id")

  book       Book?    @relation(fields: [bookId], references: [id], onDelete: Cascade)
  section    Section? @relation(fields: [sectionId], references: [id], onDelete: Cascade)
  user       User     @relation(fields: [userId], references: [id])
  resolvedBy   User?                     @relation("ReportResolver", fields: [resolvedById], references: [id])
  disposition  ReportDisposition?
  moderationLog ReportModerationLogEntry[]
  notifications Notification[]
}

model ReportModerationLogEntry {
  id          String                       @id @default(cuid())
  reportId    String                       @map("report_id")
  actorId     String                       @map("actor_id")
  createdAt   DateTime                     @default(now()) @map("created_at")
  kind        ReportModerationLogKind
  visibility  ReportModerationLogVisibility @default(PUBLIC)
  disposition ReportDisposition?
  body        String                       @db.Text

  report Report @relation(fields: [reportId], references: [id], onDelete: Cascade)
  actor  User   @relation(fields: [actorId], references: [id], onDelete: Cascade)

  @@index([reportId, createdAt])
  @@index([createdAt])
  @@map("report_moderation_log_entries")
}

model ContentDraft {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  kind      ContentDraftKind
  label     String           @db.VarChar(512)
  payload   Json
  createdAt DateTime         @default(now()) @map("created_at")
  updatedAt DateTime         @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, updatedAt(sort: Desc)])
  @@map("content_drafts")
}
